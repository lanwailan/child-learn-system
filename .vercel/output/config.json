{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/export/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/generate/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/health/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/recommend/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/recommend-v2/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/review/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/schedule/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/stats/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/review/?$",
			"dest": "_render"
		},
		{
			"src": "^/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}